{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccp.dev/schemas/evidence-pack.schema.json",
  "title": "CCP Evidence Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "change_request",
    "status",
    "acceptance_checklist",
    "artifacts",
    "unresolved_risks"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^EV-[0-9]{4}$"
    },
    "kind": {
      "const": "evidence_pack"
    },
    "change_request": {
      "type": "string",
      "pattern": "^CR-[0-9]{4}$"
    },
    "status": {
      "enum": [
        "draft",
        "submitted",
        "accepted",
        "rejected"
      ]
    },
    "acceptance_checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "criterion",
          "result"
        ],
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": [
              "pass",
              "fail",
              "partial",
              "not_applicable"
            ]
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unresolved_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}