{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccp.dev/schemas/execution-plan.schema.json",
  "title": "CCP Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "change_request",
    "status",
    "tasks",
    "validation_plan"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^EP-[0-9]{4}$"
    },
    "kind": {
      "const": "execution_plan"
    },
    "change_request": {
      "type": "string",
      "pattern": "^CR-[0-9]{4}$"
    },
    "status": {
      "enum": [
        "draft",
        "planned",
        "executing",
        "blocked",
        "done"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_plan": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "rollout_plan": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}